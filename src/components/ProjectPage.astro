---
//
//  ProjectPage.astro
//  CV Hub — Case study page template
//
//  Created by Alexander Gusarov on 30.03.2026.
//  @spartan121
//
import Layout from './Layout.astro';
import TextBlock  from './blocks/TextBlock.astro';
import ImageBlock from './blocks/ImageBlock.astro';
import Divider    from './blocks/DividerBlock.astro';

const { data, showcaseHref, langLinks, lang } = Astro.props;
---

<Layout title={data?.title ?? ''} lang={lang} section="showcase" profile="" customLangLinks={langLinks}>
<div class="project-page container">

  <!-- Nav: back + share button -->
  <nav class="project-page__nav">
    <a class="btn btn--ghost" href={showcaseHref}>← Showcase</a>
    
    {data.shareable === true && (
      <button 
        class="btn btn--ghost btn--icon share-btn" 
        type="button"
        aria-label="Copy link"
      >
        <svg class="share-btn__icon share-btn__icon--link" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
        <svg class="share-btn__icon share-btn__icon--check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    )}
  </nav>

  <!-- Header -->
  <header class="project-page__header">
    {(data.role || data.year) && (
      <div class="project-page__meta muted">
        {data.role && <span>{data.role}</span>}
        {data.role && data.year && <span>·</span>}
        {data.year && <span>{data.year}</span>}
      </div>
    )}

    <h1 class="project-page__title">{data.title}</h1>

    {data.tagline && (
      <p class="project-page__tagline muted">{data.tagline}</p>
    )}

    {(data.platforms?.length > 0 || data.stack?.length > 0) && (
      <div class="project-page__tags-row">
        {data.platforms?.length > 0 && (
          <div class="row">
            <div class="row__title">Platforms</div>
            <ul class="tags">
              {data.platforms.map((p: string) => <li class="tag">{p}</li>)}
            </ul>
          </div>
        )}
        {data.stack?.length > 0 && (
          <div class="row">
            <div class="row__title">Stack</div>
            <ul class="tags">
              {data.stack.map((s: string) => <li class="tag">{s}</li>)}
            </ul>
          </div>
        )}
      </div>
    )}

    {data.links?.filter((l: any) => l?.url).length > 0 && (
      <div class="links">
        {data.links.filter((l: any) => l?.url).map((l: any) => (
          <a class="btn" href={l.url} target="_blank" rel="noopener">{l.label}</a>
        ))}
      </div>
    )}
  </header>

  <!-- Blocks -->
  {(data.blocks ?? []).map((block: any) => {
    if (block.type === 'divider') return <Divider />;
    if (block.type === 'text')    return <TextBlock  {...block} />;
    if (block.type === 'image')   return <ImageBlock {...block} />;
    return null;
  })}

</div>

<!-- Image lightbox -->
<div class="lightbox" data-lightbox aria-hidden="true" role="dialog" aria-modal="true">
  <button class="lightbox__close" type="button" aria-label="Close">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <img class="lightbox__img" src="" alt="" />
</div>
</Layout>

<script>
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement)?.closest('.share-btn');
    if (!btn) return;

    const url = window.location.href;

    try {
      await navigator.clipboard.writeText(url);

      // Показываем галочку
      btn.classList.add('share-btn--copied');

      // Возвращаем иконку ссылки через 3 секунды
      setTimeout(() => {
        btn.classList.remove('share-btn--copied');
      }, 3000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>

<script>
  // Click-to-zoom lightbox for case-study images
  const lightbox = document.querySelector('[data-lightbox]') as HTMLElement | null;
  if (lightbox) {
    const lbImg = lightbox.querySelector('.lightbox__img') as HTMLImageElement;

    const open = (src: string, alt: string) => {
      lbImg.src = src;
      lbImg.alt = alt;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lbImg.removeAttribute('src');
    };

    document.querySelectorAll('.project-page .image-block__img').forEach((node) => {
      const img = node as HTMLImageElement;
      img.addEventListener('click', () => open(img.currentSrc || img.src, img.alt));
    });

    // Click anywhere in the lightbox (backdrop, image or close button) closes it
    lightbox.addEventListener('click', () => close());

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('is-open')) close();
    });
  }
</script>

<style>
  .project-page {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-bottom: 60px;
  }

  .project-page__nav {
    display: flex;
    align-items: center;
    justify-content: start;
    gap: 16px;
    flex-wrap: wrap;
  }

  .project-page__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .project-page__meta {
    display: flex;
    gap: 6px;
    font-size: 13px;
  }

  .project-page__title {
    margin: 0;
    font-size: clamp(24px, 4vw, 38px);
    line-height: 1.15;
  }

  .project-page__tagline {
    margin: 0;
    font-size: 16px;
    line-height: 1.5;
    max-width: 60ch;
  }

  .project-page__tags-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Share button */
  .btn--icon {
    padding: 12px;
    min-width: auto;
    position: relative;
  }

  .share-btn__icon {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .share-btn__icon--check {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    stroke: var(--success, #10b981);
  }

  .share-btn--copied .share-btn__icon--link {
    opacity: 0;
    transform: scale(0);
  }

  .share-btn--copied .share-btn__icon--check {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: clamp(16px, 4vw, 48px);
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
    cursor: zoom-out;
    animation: lightbox-in 0.18s ease;
  }

  .lightbox.is-open {
    display: flex;
  }

  .lightbox__img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: var(--r-lg);
    box-shadow: var(--shadow);
    cursor: zoom-out;
  }

  .lightbox__close {
    position: absolute;
    top: 16px;
    right: 16px;
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    cursor: pointer;
    transition: background var(--t), border-color var(--t);
  }

  .lightbox__close:hover {
    background: rgba(0, 0, 0, 0.7);
    border-color: rgba(255, 255, 255, 0.4);
  }

  @keyframes lightbox-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>